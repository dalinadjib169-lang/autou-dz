{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "wilaya": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "rating": { "type": "number" },
        "ratingCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "firstName", "lastName", "wilaya", "phone", "email", "role", "createdAt"]
    },
    "CarListing": {
      "title": "CarListing",
      "description": "Car advertisement listing",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "bidPrice": { "type": "number" },
        "condition": { "type": "string", "enum": ["excellent", "good", "average", "below_average"] },
        "year": { "type": "number" },
        "mileage": { "type": "number" },
        "engine": { "type": "string", "enum": ["Diesel", "Essence"] },
        "gearbox": { "type": "string", "enum": ["Manuelle", "Automatique"] },
        "engineState": { "type": "string", "enum": ["heats", "consumes", "consumes_little", "perfect"] },
        "bodyState": { "type": "string" },
        "replacedParts": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "wilaya": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerPhone": { "type": "string" },
        "showPhone": { "type": "boolean" },
        "isVerified": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "sold"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "price", "condition", "year", "engine", "gearbox", "engineState", "bodyState", "brand", "model", "wilaya", "images", "sellerId", "sellerName", "sellerPhone", "showPhone", "isVerified", "status", "createdAt"]
    },
    "ChatThread": {
      "title": "ChatThread",
      "description": "A conversation between two users about a car",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "carId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "carId", "lastMessage", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat thread",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a car listing",
      "type": "object",
      "properties": {
        "carId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["carId", "userId", "userName", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/cars/{carId}": {
      "schema": "CarListing",
      "description": "Car listing documents"
    },
    "/chats/{chatId}": {
      "schema": "ChatThread",
      "description": "Chat thread documents"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat thread"
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on car listings"
    }
  }
}
